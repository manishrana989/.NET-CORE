@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.RevistaReEncuentro>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "Master.cshtml";
}

<!-- ======= Breadcrumbs ======= -->
    <div class="breadcrumbs">
        <div class="page-header d-flex align-items-center" style="background-image: url('');">
            <div class="container position-relative">
                <div class="row d-flex justify-content-center">
                    <div class="col-lg-6 text-center">
                        <h2 style="padding: 10px;">Revista ReEncuentro</h2>
                        <p>
                            Esta revista ha sido creada teniendo en mente las necesidades y diferentes circunstancias por las que
                            atraviesa una persona que ha sufrido una perdida significativa. Se abordan los diferentes aspectos del
                            duelo tratando de poner al alcance un material útil y a su vez simple de comprender. Rogamos a Dios
                            por fortaleza para el necesitado y que este material sea de utilidad en la vida de los lectores.
                        </p>
                    </div>
                </div>
            </div>
        </div>
        <nav>
            <div class="container">
                <ol>
                    <li><a href="/">Inicio</a></li>
                    <li>Revista ReEncuentro</li>
                </ol>
            </div>
        </nav>
    </div>
    <!-- End Breadcrumbs -->
    
    <main id="main"> 
    
    <!-- ======= Blog Section ======= -->
    <section id="blog" class="blog">
      <div class="container" data-aos="fade-up">

        <div class="row gy-4 posts-list">  
          
            @{
            	var selection = Umbraco.Content(Guid.Parse("cb59b53b-f256-46bb-bb13-df9b96615340"))
                .ChildrenOfType("revista")
                .Where(x => x.IsVisible())
                .OrderByDescending(x => x.CreateDate);
            } 
            
        	@foreach (var item in selection)
        	{
        	var image = item.Value<IPublishedContent>("revistaImagen");

        	<div class="col-xl-4 col-md-6">
            <article>   
            <div class="post-img">
                @if (image is not null)
                    {
                    <a href="@item.Url()"><img src="@image.Url()" alt="" class="img-fluid"></a>
                    }
                </div>
        	<h2 class="title">
                <a href="@item.Url()">@item.Value("revistaTitle")</a>
             </h2>
             </article>
          </div><!-- End post list item -->
         }     
        </div><!-- End blog posts list -->
      
       

      </div>
    </section>
    
    <!-- End Blog Section -->
</main>