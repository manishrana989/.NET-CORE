@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Noticia>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "Master.cshtml";
	
	var image = Model.Value<IPublishedContent>("noticiaImagen");  

}

<main id="main">

    <!-- ======= Breadcrumbs ======= -->
    <div class="breadcrumbs">
        <div class="page-header d-flex align-items-center" style="background-image: url('');">
            <div class="container position-relative">
                <div class="row d-flex justify-content-center">
                    <div class="col-lg-6 text-center">
                        <h2>Noticias</h2>
                        <p>
                           Aquí podrá mantenerse informado de todos los eventos del Ministerio AME incluyendo 
                           sus periodos de Matrícula. También encontrará temas espirituales y emocionales que 
                           serán de ayuda para usted o algún conocido. 
                        </p>
                    </div>
                </div>
            </div>
        </div>
        <nav>
            <div class="container">
                <ol>
                    <li><a href="/">Inicio</a></li>
                    <li>Noticias</li>
                </ol>
            </div>
        </nav>
    </div><!-- End Breadcrumbs -->
    <!-- ======= Blog Details Section ======= -->
    <section id="blog" class="blog">
        <div class="container" data-aos="fade-up">

            <div class="row g-5">

                <div class="col-lg-12">

                    <article class="blog-details">
                         
                        <div class="post-img" style="max-height: 1024px;">
                            @if(image is not null) { 
                            <img src="@image.Url()" alt="" class="img-fluid">
                            }
                        </div>

                        <h2 class="title" style="text-align:center">
                            @Model.Value("noticiaTitulo")
                            </h2> 
                        
                        <div class="content">
                            <p>@Model.Value("noticiaTexto")</p>
                            <br>
                            @if (Model.HasValue("noticiaAudio")) {  
                            <audio controls src="@Model.Value("noticiaAudio")"></audio>
                            }
                        </div>
                        <!-- End post content -->
                        @*
                        <div class="meta-bottom">
                            <i class="bi bi-folder"></i>
                            <ul class="cats">
                                <li><a href="#"></a></li>
                            </ul>

                            <i class="bi bi-tags"></i>
                            <ul class="tags">
                                <li><a href="#"></a></li>
                                <li><a href="#"></a></li>
                                <li><a href="#"></a></li>
                            </ul>
                        </div><!-- End meta bottom -->
                        *@

                    </article><!-- End blog post -->

                </div> 

            </div>

        </div>
    </section><!-- End Blog Details Section -->

</main>