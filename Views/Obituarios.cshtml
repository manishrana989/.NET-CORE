@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Obituarios>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "Master.cshtml"; 
	
}


<main id="main">

    <!-- ======= Breadcrumbs ======= -->
    <div class="breadcrumbs">
      <div class="page-header d-flex align-items-center" style="background-image: url('');">
        <div class="container position-relative">
          <div class="row d-flex justify-content-center">
            <div class="col-lg-6 text-center">
              <h2>Obituarios</h2>
              <p>
                  En memoria amorosa de aquellos que han pasado al descaso, honramos sus vidas y legados aquí. Este
                  espacio es dedicado a recordar a quienes nos dejaron. Sus recuerdos y sus obras perduran en nuestros
                  corazones para siempre.
              </p>
            </div>
          </div>
        </div>
      </div>
      <nav>
        <div class="container">
          <ol>
            <li><a href="/">Inicio</a></li>
            <li>Obituarios</li>
          </ol>
        </div>
      </nav>
    </div><!-- End Breadcrumbs --> 
    
    <!-- ======= Blog Section ======= -->
    <section id="blog" class="blog">
      <div class="container" data-aos="fade-up">

        <div class="row gy-4 posts-list">  
          
            @{
            	var selection = Umbraco.Content(Guid.Parse("4bf8ff9b-4d04-4953-8a01-7a235c1802e7"))
                .ChildrenOfType("obituario")
                .Where(x => x.IsVisible())
                .OrderByDescending(x => x.CreateDate);
            } 
            
        	@foreach (var item in selection)
        	{
        	var image = item.Value<IPublishedContent>("Imagen");
        	<div class="col-xl-4 col-md-6">
            <article>   
            <div class="post-img">
                @if (image is not null)
                    {
                    <a href="@item.Url()"><img src="@image.Url()" alt="" class="img-fluid"></a>
                    }
            </div>
        	<h2 class="title">
                <a href="@item.Url()">@item.Value("Nombre")</a>
             </h2>
             </article>
          </div><!-- End post list item -->
         }     
        </div><!-- End blog posts list -->
      
       

      </div>
    </section>
    
    <!-- End Blog Section -->
</main>