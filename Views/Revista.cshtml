@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Revista>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "Master.cshtml";
	var image = Model.Value<IPublishedContent>("revistaImagen");
}


<main id="main">

    <!-- ======= Breadcrumbs ======= -->
    <div class="breadcrumbs">
        <div class="page-header d-flex align-items-center" style="background-image: url('');">
            <div class="container position-relative">
                <div class="row d-flex justify-content-center">
                    <div class="col-lg-6 text-center">
                        <h2>Revista ReEncuentro</h2>
                        <p>
                             Esta revista ha sido creada teniendo en mente las necesidades y diferentes circunstancias por 
                             las que atraviesa una persona que ha sufrido una perdida significativa. Se abordan los 
                             diferentes aspectos del duelo tratando de poner al alcance un material útil y a su vez 
                             simple de comprender. Rogamos a Dios por fortaleza para el necesitado y que este material 
                             sea de utilidad en la vida de los lectores. 
                        </p>
                    </div>
                </div>
            </div>
        </div>
        <nav>
            <div class="container">
                <ol>
                    <li><a href="/">Inicio</a></li>
                    <li>Revista ReEncuentro</li>
                </ol>
            </div>
        </nav>
    </div><!-- End Breadcrumbs -->
    <!-- ======= Blog Details Section ======= -->
    <section id="blog" class="blog">
        <div class="container" data-aos="fade-up">

            <div class="row g-5">

                <div class="col-lg-12">

                    <article class="blog-details">
                         
                         @Model.Value("revistaHTML")

                        <h2 class="title"> @Model.Value("revistaTitle") </h2> 

                        <div class="meta-bottom">
                            <i class="bi bi-folder"></i>
                            <ul class="cats">
                                <li><a href="#"></a></li>
                            </ul>

                            <i class="bi bi-tags"></i>
                            <ul class="tags">
                                <li><a href="#"></a></li>
                                <li><a href="#"></a></li>
                                <li><a href="#"></a></li>
                            </ul>
                        </div><!-- End meta bottom -->

                    </article><!-- End blog post -->

                </div> 

            </div>

        </div>
    </section><!-- End Blog Details Section -->

</main>